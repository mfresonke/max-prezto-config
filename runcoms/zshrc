# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
	source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Customize to your needs...


# ======== Standard Stuff ========

# Setup Keychain for ssh management
if command -v keychain > /dev/null ; then
	eval `keychain --eval --agents ssh --quiet`
else
	echo "keychain command not found."
fi


# Don't Add to History if Space Is Prepended to Command
setopt histignorespace

# User Bins
if [ -d "$HOME/bin" ] ; then
	export PATH=$PATH:$HOME/bin
fi

# Go
if [ -d "$HOME/go" ] ; then
	export GOPATH=$HOME/go
	export PATH=$PATH:$GOPATH/bin
	export GO15VENDOREXPERIMENT=1
fi

# Docker Configs
alias dke='docker-compose exec'
alias dkc='docker-compose'

# ======== Mac Specific Configs ========

export ANDROID_HOME=$HOME/Library/Android/sdk
if [ -d "$ANDROID_HOME" ] ; then
        export PATH=$PATH:$ANDROID_HOME/platform-tools
fi

# MySQL Utils
mysql_utils_loc="/Applications/MySQLWorkbench.app/Contents/MacOS"
if [ -d "$mysql_utils_loc" ] ; then
	export PATH=$PATH:$mysql_utils_loc
fi

# ======== Computer/Job Specific Configs ========

# Bahamas Ride Helper Vars
mysql_configs_dir="$HOME/Knight/Bahamas_Ride/Backend/database/configs"
if [ -d "$mysql_configs_dir" ] ; then
        export BR_SQL_CFGS="$mysql_configs_dir"
fi

# Super Secret Parameters
alias max="echo 'A god. A true master. Check out his work at http://github.com/mfresonke'"
alias lolz='fortune | tee >(say) | cowsay -f bong'
